<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <NoWarn>$(NoWarn);StreamJsonRpc0003;MCPEXP001</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="CopilotCliIde.Server.Tests" />
    <InternalsVisibleTo Include="PipeProxy" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="ModelContextProtocol" />
    <PackageReference Include="ModelContextProtocol.AspNetCore" />
    <!-- We need this one compatible with ModelContextProtocol -->
    <PackageReference Include="StreamJsonRpc" VersionOverride="[2.24.84]" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\CopilotCliIde.Shared\CopilotCliIde.Shared.csproj" />
  </ItemGroup>
</Project>
